# Database Configuration
# Get your connection string from MongoDB Atlas
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/food-delivery-app

# Authentication
# Create a secure random string for JWT
JWT_SECRET=your_super_secret_jwt_key_here

# Client Configuration
# Use your production frontend URL (e.g., https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# Server Port (optional)
PORT=3000
